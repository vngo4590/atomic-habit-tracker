# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Database
# Use a pooled PostgreSQL URL in Vercel production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atomicly?schema=public"

