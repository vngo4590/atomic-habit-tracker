# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Database
# Local Docker Postgres uses docker-compose.yml defaults.
# Use a pooled PostgreSQL URL in Vercel production.
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/atomicly?schema=public"

# Optional OAuth providers can be added later without changing the domain model.
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# Bot protection (Cloudflare Turnstile) — optional.
# When unset, the login/register bot challenge is skipped (dev/test default).
# Create keys at https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""
