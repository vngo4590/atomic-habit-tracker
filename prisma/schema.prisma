generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Theme {
  light
  dark
}

enum LessonMode {
  sequential
  random
}

enum FormationDecision {
  formed
  keep_practicing
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  preferences       UserPreference?
  identityProfile   IdentityProfile?
  habits            Habit[]
  habitCheckIns     HabitCheckIn[]
  habitNotes        HabitNote[]
  habitContracts    HabitContract[]
  journalEntries    JournalEntry[]
  weeklyReviews     WeeklyReview[]
  lessonProgress    LessonProgress[]
  formationVerdicts FormationVerdict[]
  pets              Pet[]
  petFeedLogs       PetFeedLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model UserPreference {
  id                  String     @id @default(cuid())
  userId              String     @unique
  theme               Theme      @default(light)
  accentHue           Int        @default(60)
  remindersEnabled    Boolean    @default(true)
  weeklyReviewNudge   Boolean    @default(true)
  accountabilityNudge Boolean    @default(false)
  onboardingSeen      Boolean    @default(false)
  lessonMode          LessonMode @default(sequential)
  timezone            String     @default("UTC")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IdentityProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  statement String   @default("")
  values    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id           String    @id @default(cuid())
  userId       String
  name         String
  emoji        String    @default("•")
  cue          String    @default("")
  craving      String    @default("")
  response     String    @default("")
  reward       String    @default("")
  loopCue      String    @default("")
  loopCraving  String    @default("")
  loopResponse String    @default("")
  loopReward   String    @default("")
  twoMin       String    @default("")
  identity     String
  environment  String    @default("")
  schedule     String    @default("Daily")
  time         String    @default("Morning")
  sortOrder    Int       @default(0)
  stackNextId  String?   @unique
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stackNext Habit?             @relation("StackChain", fields: [stackNextId], references: [id], onDelete: SetNull)
  stackPrev Habit?             @relation("StackChain")
  checkIns  HabitCheckIn[]
  notes     HabitNote[]
  contract  HabitContract?
  verdicts  FormationVerdict[]

  @@index([userId, createdAt])
  @@index([userId, archivedAt])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  dateKey   String
  done      Boolean  @default(true)
  mood      Int?
  journal   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, dateKey])
  @@index([userId, dateKey])
}

model HabitNote {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([userId, habitId])
}

model HabitContract {
  id        String   @id @default(cuid())
  userId    String
  habitId   String   @unique
  terms     String   @default("")
  partners  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String
  title     String
  body      String   @default("")
  mood      String   @default("good")
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
}

model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  weekStartKey String
  wentWell     String   @default("")
  smallestFix  String   @default("")
  identityVote String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartKey])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    Int
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model FormationVerdict {
  id         String            @id @default(cuid())
  userId     String
  habitId    String
  score      Float
  reflection String            @default("")
  decision   FormationDecision
  reviewedAt DateTime          @default(now())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId])
  @@index([userId, decision])
}

// A procedurally generated Tamagotchi-style companion. Its appearance is NOT
// stored — only the `seed` + `temperament` genome, from which the sprite is
// always regenerated deterministically. The remaining columns are the
// time-varying "vital signs" the simulation advances (see lib/pet/simulation.ts):
// the pet gets hungry over real time and can die permanently if neglected.
model Pet {
  id          String    @id @default(cuid())
  userId      String
  name        String
  // Genome: the two values that fully determine the creature's look.
  temperament String
  seed        Int
  // Lifetime feeds drive evolution from egg -> hatchling -> ... -> elder.
  totalFeeds  Int       @default(0)
  // Vital signs (advanced by the pure simulation on read and on feed).
  satiety     Float     @default(4)
  health      Float     @default(100)
  bornAt      DateTime  @default(now())
  lastFedAt   DateTime  @default(now())
  lastSimAt   DateTime  @default(now())
  isAlive     Boolean   @default(true)
  diedAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedLogs PetFeedLog[]

  @@index([userId, isAlive])
}

// One row per feeding event. Summing `amount` for a user on a given dateKey is
// how we enforce the SHARED daily food pool: food earned from completing habits
// today is spent across the whole ecosystem, not per-pet.
model PetFeedLog {
  id        String   @id @default(cuid())
  userId    String
  petId     String
  dateKey   String
  amount    Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
  @@index([petId, dateKey])
}
